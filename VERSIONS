# Minimum versions this DE assumes. On Arch you get these from the rolling repos
# (pacman) + AUR, so there's nothing to pin — this file is documentation of the
# floor, not a lockfile.
#
# Hyprland MUST be >= 0.55 — that's where the Lua config (hyprland.lua) landed.
# Anything older silently ignores the config and the DE won't come up right.
hyprland >= 0.55
quickshell >= 0.2
