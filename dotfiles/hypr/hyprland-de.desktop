[Desktop Entry]
# Wayland session entry for the custom Hyprland desktop. install.sh copies this
# to /usr/local/share/wayland-sessions/ (system-wide) so GDM's pre-login greeter
# — which runs as the gdm user and never reads ~/.local/share — lists it.
# The COPR also installs a stock "Hyprland" session; this "(DE)" one runs through
# start-hyprland.sh to add the DE_SOFTWARE_RENDER escape hatch + desktop identity.
Name=Hyprland (DE)
Comment=Hyprland with the custom macOS-style desktop
Exec=/home/scubba/.config/hypr/start-hyprland.sh
Type=Application
DesktopNames=Hyprland
Keywords=tiling;wayland;wm;
