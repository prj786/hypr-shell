#%PAM-1.0
# Installed to /etc/pam.d/greetd by phase 30. Adds gnome-keyring so the login
# keyring is unlocked with your password as you log in through ReGreet — so the
# "Authentication required / login keyring did not get unlocked" prompt never
# appears. The keyring is created with (and stays in sync with) your login
# password, so it stays encrypted at rest.
auth       include    system-login
-auth      optional   pam_gnome_keyring.so

account    include    system-login

password   include    system-login
-password  optional   pam_gnome_keyring.so use_authtok

session    include    system-login
-session   optional   pam_gnome_keyring.so auto_start
