[Desktop Entry]
Type=Application
Name=Fresh
GenericName=Text Editor
Comment=Fresh — terminal IDE
# Run Fresh inside kitty so it works as a GUI file association (kitty is the
# terminal; Terminal=false because we spawn our own).
Exec=kitty -e fresh %F
TryExec=fresh
Icon=fresh
Terminal=false
StartupNotify=false
Categories=Development;TextEditor;
MimeType=text/plain;text/markdown;text/html;text/css;text/javascript;application/json;application/javascript;application/xml;text/xml;application/x-yaml;text/x-python;text/x-csrc;text/x-chdr;text/x-c++src;application/x-shellscript;text/x-rust;text/x-go;
Keywords=editor;ide;code;text;
