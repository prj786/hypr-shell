[Desktop Entry]
# Rendered by phase 30 into the wayland-sessions dirs so the greeter (greetd +
# ReGreet), which runs as the `greeter` user and never reads ~/.local/share,
# lists it. @EXEC@ is replaced with the per-user path to start-hyprland.sh at
# install time.
Name=Hyprland (DE)
Comment=Hyprland with the Quickshell desktop
Exec=@EXEC@
Type=Application
DesktopNames=Hyprland
Keywords=tiling;wayland;wm;
