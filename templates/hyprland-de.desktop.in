[Desktop Entry]
# Rendered by phase 30 into /usr/local/share/wayland-sessions/ so the greeter
# (greetd/regreet or SDDM), which runs as its own user and never reads
# ~/.local/share, lists it. @EXEC@ is replaced with the per-user path to
# start-hyprland.sh at install time.
Name=Hyprland (DE)
Comment=Hyprland with the macOS-style Quickshell desktop
Exec=@EXEC@
Type=Application
DesktopNames=Hyprland
Keywords=tiling;wayland;wm;
