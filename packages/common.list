# common.list — official-repo (pacman) packages, real Arch names, one per line.
# AUR packages live in aur.list. GPU/Vulkan drivers are installed per-vendor by
# phase 40, not here. Comments (#) and blank lines are ignored.

# ── core session ─────────────────────────────────────────────────────────────
hyprland
quickshell
hypridle
hyprlock
xdg-desktop-portal
xdg-desktop-portal-hyprland
xdg-desktop-portal-gtk
polkit
gnome-keyring
qt5-wayland
qt6-wayland
qt6-svg
qt6-5compat
qt6-multimedia-ffmpeg
xdg-user-dirs
xdg-utils

# ── greeter / welcome screen — FULLY WAYLAND, zero Xorg. greetd is the login
#    daemon; ReGreet (gtk4-layer-shell, Wayland-native) is the graphical greeter,
#    rendered by `cage` (a one-shot kiosk Wayland compositor). regreet is in the
#    AUR (see aur.list). No xorg-server anywhere. ───────────────────────────────
greetd
cage

# ── audio (PipeWire, low-latency-ready) ──────────────────────────────────────
pipewire
pipewire-pulse
pipewire-alsa
pipewire-jack
wireplumber
pavucontrol

# ── network / bluetooth / power ──────────────────────────────────────────────
networkmanager
iwd
bluez
bluez-utils
blueman
power-profiles-daemon

# ── terminals ────────────────────────────────────────────────────────────────
foot
ghostty

# ── file manager + mounting + thumbnails + archives ──────────────────────────
nautilus
gvfs
gvfs-mtp
gvfs-smb
udisks2
ffmpegthumbnailer
file-roller
unzip
p7zip

# ── browser / editors ────────────────────────────────────────────────────────
