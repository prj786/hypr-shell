# common.list — official-repo (pacman) packages, real Arch names, one per line.
# AUR packages live in aur.list. GPU/Vulkan drivers are installed per-vendor by
# phase 40, not here. Comments (#) and blank lines are ignored.

# ── core session ─────────────────────────────────────────────────────────────
hyprland
quickshell
hypridle
hyprlock
xdg-desktop-portal
xdg-desktop-portal-hyprland
xdg-desktop-portal-gtk
polkit
gnome-keyring
qt5-wayland
qt6-wayland
qt6-svg
qt6-5compat
qt6-multimedia-ffmpeg
xdg-user-dirs
xdg-utils

# ── greeter / welcome screen — FULLY WAYLAND, zero Xorg. greetd is the login
#    daemon; ReGreet (gtk4-layer-shell, Wayland-native) is the graphical greeter,
#    rendered by `cage` (a one-shot kiosk Wayland compositor). All three are in
#    the official extra repo. No xorg-server anywhere. ──────────────────────────
greetd
greetd-regreet
cage

# ── audio (PipeWire, low-latency-ready) ──────────────────────────────────────
pipewire
pipewire-pulse
pipewire-alsa
pipewire-jack
wireplumber
pavucontrol

# ── network / bluetooth / power ──────────────────────────────────────────────
networkmanager
iwd
bluez
bluez-utils
blueman
power-profiles-daemon

# ── terminal (single, fast, GPU-accelerated) + multiplexer ───────────────────
# kitty is the one terminal (foot/ghostty dropped). It auto-attaches a themed
# tmux session — see dotfiles/kitty/kitty.conf + dotfiles/tmux/tmux.conf.
kitty
tmux

# ── file manager + utility apps = traditional GTK (NOT libadwaita) ────────────
#    Nemo/Engrampa/Zathura use a normal menubar/toolbar + server-side decorations,
#    so under Hyprland (no titlebar) they render with ONLY our accent border — the
#    no-titlebar macOS look — while theming via GTK (adw-gtk3 + gsettings, see
#    scripts/colorscheme.sh). Unlike GNOME/libadwaita apps they have no unhideable
#    client-side headerbar. Defaults are managed the standard way: ONE
#    ~/.config/mimeapps.list, read natively by GIO — no KDE ksycoca cache, so
#    "Open With" always sees the installed apps. ──────────────────────────────
nemo                    # file manager (GTK3; custom right-click via .nemo_action)
engrampa                # archive manager (GTK3, no headerbar) — create / extract
imv                     # image viewer (Wayland-native, decorationless)
zathura                 # PDF / document viewer (keyboard-driven, fully themeable)
zathura-pdf-mupdf       # PDF backend for zathura
mpv                     # video player (decorationless, themeless — ideal)
ffmpegthumbnailer       # video thumbnails in Nemo
# mounting + filesystem access for GTK apps (trash, network, MTP; cloud via GOA later)
gvfs
gvfs-mtp
gvfs-smb
udisks2
unzip
p7zip

# ── browser + editor ──────────────────────────────────────────────────────────
# Terminal IDE is Fresh (AUR: fresh-editor, see aur.list) — the default text/code
# editor. neovim/vim dropped; no GUI text editor ships (Fresh covers it).
firefox

# ── desktop utilities ────────────────────────────────────────────────────────
swaybg
grim
slurp
satty
cliphist
wl-clipboard
hyprpicker
brightnessctl
playerctl
jq
socat

# ── theming (GTK primary) + fonts ────────────────────────────────────────────
adw-gtk-theme
gnome-themes-extra
# GTK is the primary toolkit now, so theming flows through adw-gtk3 + gsettings.
# qt6ct just gives a dark Fusion palette to any stray Qt app you install (the shell
# itself is Quickshell/Qt but themed by Theme.qml). No more plasma-integration / kde
# platform theme — we ship no KDE apps.
qt6ct
papirus-icon-theme      # fallback icon set (Reversal inherits/falls back to it)
librsvg                  # rsvg-convert — builds the Mocu cursor (phase 20 source step)
xorg-xcursorgen          # xcursorgen — builds the Mocu cursor
xmlstarlet               # cursor hotspot extraction for the Mocu build
noto-fonts
noto-fonts-emoji
ttf-jetbrains-mono-nerd
ttf-nerd-fonts-symbols-mono
inter-font

# ── dev tooling ──────────────────────────────────────────────────────────────
# Front-end focused. Node/npm/pnpm + the language servers are NOT pacman packages
# here — mise owns the Node toolchain (dotfiles/mise/config.toml provisions
# node LTS, pnpm and the LSP/formatter binaries; phase 60 runs `mise install`).
git                     # pre-installed VCS (also used by the AUR bootstrap)
git-delta               # nicer git diffs
lazygit                 # TUI git client
github-cli              # GitHub CLI (provides the `gh` command)
mise                    # polyglot runtime/version manager — owns Node here
ripgrep                 # fast search (rg)
fd                      # fast file find
fzf                     # fuzzy finder
bat                     # syntax-highlighting pager
podman                  # rootless containers

# ── gaming (needs multilib — phase 10 enables it) ────────────────────────────
steam
gamemode
lib32-gamemode
gamescope
mangohud
lib32-mangohud
mesa
lib32-mesa
vulkan-icd-loader
lib32-vulkan-icd-loader

# ── system tuning ────────────────────────────────────────────────────────────
zram-generator

# ── build deps (AUR builds + hyprpm plugins) ─────────────────────────────────
base-devel
cmake
meson
