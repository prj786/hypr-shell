# common.list — official-repo (pacman) packages, real Arch names, one per line.
# AUR packages live in aur.list. GPU/Vulkan drivers are installed per-vendor by
# phase 40, not here. Comments (#) and blank lines are ignored.

# ── core session ─────────────────────────────────────────────────────────────
hyprland
quickshell
hypridle
hyprlock
xdg-desktop-portal
xdg-desktop-portal-hyprland
xdg-desktop-portal-gtk
polkit
gnome-keyring
qt5-wayland
qt6-wayland
qt6-svg
qt6-5compat
qt6-multimedia-ffmpeg
xdg-user-dirs
xdg-utils

# ── greeter / welcome screen — FULLY WAYLAND, zero Xorg. greetd is the login
#    daemon; ReGreet (gtk4-layer-shell, Wayland-native) is the graphical greeter,
#    rendered by `cage` (a one-shot kiosk Wayland compositor). All three are in
#    the official extra repo. No xorg-server anywhere. ──────────────────────────
greetd
greetd-regreet
cage

# ── audio (PipeWire, low-latency-ready) ──────────────────────────────────────
pipewire
pipewire-pulse
pipewire-alsa
pipewire-jack
wireplumber
pavucontrol

# ── network / bluetooth / power ──────────────────────────────────────────────
networkmanager
iwd
bluez
bluez-utils
blueman
power-profiles-daemon

# ── terminals ────────────────────────────────────────────────────────────────
foot
ghostty

# ── file manager + utility apps = Qt/KDE (no client-side titlebar; themed to
#    match the shell via kdeglobals + qt6ct). GTK is kept for browsers/3rd-party
#    apps below. With QT_WAYLAND_DISABLE_WINDOWDECORATION=1 (set in hyprland.lua)
#    these render borderless — only the Hyprland accent border, macOS-clean. ────
dolphin                 # file manager
ark                     # archive manager (replaces file-roller)
gwenview                # image viewer
okular                  # PDF / document viewer
kate                    # advanced text editor (GUI)
mpv                     # video player (decorationless, themeless — ideal)
kio-extras              # smb/sftp/mtp/etc protocols for Dolphin
kio-fuse                # mount kio locations so non-KDE apps can read them
kdegraphics-thumbnailers # PDF/image thumbnails in Dolphin
ffmpegthumbs            # video thumbnails in Dolphin
kimageformats           # avif/heif/jxl… support for Gwenview/Dolphin
kde-cli-tools           # kioclient / kde-open (file associations, "open with")
# mounting + GTK-app filesystem access (browsers, Electron apps still want gvfs)
gvfs
gvfs-mtp
gvfs-smb
udisks2
unzip
p7zip

# ── browser / editors (GTK / terminal — kept for 3rd-party app parity) ─────────
firefox
neovim
vim

# ── desktop utilities ────────────────────────────────────────────────────────
swaybg
swww
grim
slurp
satty
cliphist
wl-clipboard
hyprpicker
brightnessctl
playerctl
jq
socat

# ── theming (GTK + Qt unified) + fonts ───────────────────────────────────────
adw-gtk-theme
gnome-themes-extra
qt6ct
kvantum
papirus-icon-theme
noto-fonts
noto-fonts-emoji
ttf-jetbrains-mono-nerd
ttf-nerd-fonts-symbols-mono
inter-font

# ── dev tooling ──────────────────────────────────────────────────────────────
git
git-delta
lazygit
mise
podman

# ── gaming (needs multilib — phase 10 enables it) ────────────────────────────
steam
gamemode
lib32-gamemode
gamescope
mangohud
lib32-mangohud
mesa
lib32-mesa
vulkan-icd-loader
lib32-vulkan-icd-loader

# ── system tuning ────────────────────────────────────────────────────────────
zram-generator

# ── build deps (AUR builds + hyprpm plugins) ─────────────────────────────────
base-devel
cmake
meson
